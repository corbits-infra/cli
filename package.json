{
  "name": "@corbits/cli",
  "version": "0.0.1",
  "description": "CLI tool for browsing and filtering x402-gated services",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "corbits": "dist/index.js"
  },
  "scripts": {
    "build": "make build",
    "lint": "make lint",
    "format": "make format"
  },
  "keywords": [],
  "author": "",
  "license": "LGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {

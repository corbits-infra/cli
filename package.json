      "tests/*.test.ts"
    ],
    "plugin": [
      "!@tapjs/typescript",
      "@tapjs/tsx"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tapjs/tsx": "^3.4.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tap": "^21.6.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@faremeter/info": "^0.19.0",
    "@faremeter/payment-evm": "^0.19.0",
    "@faremeter/payment-solana": "^0.19.0",
    "@faremeter/types": "^0.19.0",
    "@faremeter/wallet-evm": "^0.19.0",
    "@faremeter/wallet-solana": "^0.19.0",
    "@open-wallet-standard/core": "^1.2.4",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "arktype": "^2.2.0",
    "cli-table3": "^0.6.5",
